{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/leoprevent-plugin\" --agent=codex",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/leoprevent-plugin\" --agent=codex",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
